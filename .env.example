
# Verification Token: Chuỗi tự bạn định nghĩa để dán vào cài đặt Webhook của Facebook
FACEBOOK_VERIFY_TOKEN=

# App Secret: Lấy tại mục Cài đặt cơ bản của Ứng dụng Meta. Dùng để sinh mã chứng thực bảo mật HMAC SHA-256 (bắt buộc)
FACEBOOK_APP_SECRET=

# Page Access Token: Dùng để gọi API ngược lại cho Facebook (ví dụ: lấy tên, ảnh đại diện dựa trên ID khách hàng nhắn tin)
FACEBOOK_PAGE_ACCESS_TOKEN=

# Supabase: Lấy tại Project Settings → API trong Supabase Dashboard
# Dùng Service Role Key (không phải anon key) để server có thể ghi DB
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key